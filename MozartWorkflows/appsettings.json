{
    "Logging": {
        "LogLevel": {
            "Default": "Information",
            "Microsoft.AspNetCore": "Warning"
        }
    },
    "AllowedHosts": "*",
    "EncryptionEnabled": false,
    "DatabaseProvider": "SqlServer",
  "ConnectionStrings": {
    "connectionString": "Data Source=<SERVER>;Initial Catalog=<DB>;Integrated Security=True;Connect Timeout=30;Encrypt=True;Trust Server Certificate=True;Application Intent=ReadWrite;Multi Subnet Failover=False"
  },
    "Gupshup": {
        "Sms": {
            "Url": "https://enterprise.smsgupshup.com/GatewayAPI/rest",
            "Username": "<GUPSHUP_SMS_USERNAME>",
            "Password": "<GUPSHUP_SMS_PASSWORD>",
            "SenderId": "<GUPSHUP_SMS_SENDER_ID>"
        },
        "WhatsApp": {
            "Url": "https://api.gupshup.io/wa/api/v1/template/msg",
            "ApiKey": "<GUPSHUP_WHATSAPP_API_KEY>",
            "Source": "<GUPSHUP_WHATSAPP_SOURCE>",
            "AppName": "<GUPSHUP_WHATSAPP_APP_NAME>"
        },
        "Email": {
            "Url": "https://enterprise.webaroo.com/GatewayAPI/rest",
            "UserId": "<GUPSHUP_EMAIL_USER_ID>",
            "Password": "<GUPSHUP_EMAIL_PASSWORD>",
            "Name": "<GUPSHUP_EMAIL_NAME>"
        }
    },
    "AllowOrigin": {
        "url": "http://localhost:4200"
    },
    "jwt": {
        "Key": "<JWT_SIGNING_KEY>",
        "Algorithm": "HS256",
        "AccessTokenExpiry": 30,
        "RefreshTokenExpiry": 7,
        "ResetExpiryTime": 10,
        "ClockSkewMinutes": 2,
        "GenerateRefreshToken": true,
        "Session": {
            "EnableTracking": true,
            "IdleTimeoutMinutes": 20,
            "AbsoluteTimeoutHours": 8,
            "MaxSessionsPerUser": 1
        }
    },
    "Elsa": {
        "Server": {
            "BaseUrl": "https://localhost:7002/"
        },
        "RetentionServices": {
            "SweepInterval": 3,
            "TimeToLive": 3
        }
    },
    "Cache": {
        "ExpiryTime": 5
    },
    "PasswordHash": {
        "SaltSize": 10,
        "HashSize": 20,
        "Iteration": 1000
    },
    "EmailSettings": {
        "Email": "<SMTP_EMAIL>",
        "Password": "<SMTP_APP_PASSWORD>",
        "Host": "smtp.gmail.com",
        "Displayname": "MonoceptWorkflows",
        "Port": 587
    },
    "Twilio": {
        "AccountSid": "<TWILIO_ACCOUNT_SID>",
        "AuthToken": "<TWILIO_AUTH_TOKEN>",
        "FromNumber": "<TWILIO_FROM_NUMBER>"
    },
    "AuditLogging": {
        "Mode": "Database",
        "LogFilePath": "logs/audit-log.txt"
    },
    "AzureDocumentIntelligence": {
        "Endpoint": "<AZURE_DOC_INTELLIGENCE_ENDPOINT>",
        "ApiKey": "<AZURE_DOC_INTELLIGENCE_API_KEY>",
        "ModelId": "prebuilt-layout"
    },
    "Serilog": {
        "Using": [ "Serilog.Sinks.File", "Serilog.Sinks.Console" ],
        "MinimumLevel": "Information",
        "WriteTo": [
            {
                "Name": "Console"
            },
            {
                "Name": "File",
                "Args": {
                    "path": "logs/audit-.log",
                    "rollingInterval": "Day",
                    "shared": true,
                    "retainedFileCountLimit": 30
                }
            }
        ],
        "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId" ]
    },
    "BatchConfig": {
        "BatchSize": 100,
        "MaxWaitMs": 20000
    },
    "AzureAd": {
        "TenantId": "<AZURE_AD_TENANT_ID>",
        "ClientId": "<AZURE_AD_CLIENT_ID>",
        "ClientSecret": "<AZURE_AD_CLIENT_SECRET>",
        "WebhookNotificationUrl": "<AZURE_AD_WEBHOOK_URL>"
    },
    "TeamsSync": {
        "Enabled": false,
        "UserId": ""
    },
    "testMood": true,
    "preloadTables": [
        "Master_LIFE_INS_001_PREMIUMS"
    ]
}